# =============================================================
# Supabase / PostgreSQL
# =============================================================

# Pooled connection — used by the API at runtime (serverless-safe)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL=

# Direct connection — used by Prisma for migrations only
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DIRECT_URL=

# =============================================================
# Auth
# =============================================================
JWT_SECRET=change-me-in-production

# =============================================================
# Redis (optional — caching is disabled gracefully if not set)
# =============================================================
# REDIS_URL=redis://localhost:6379

# =============================================================
# API
# =============================================================
PORT=4000
NODE_ENV=development

# =============================================================
# GitHub Actions — Translation Sync Workflow
# Set these as GitHub Repository Secrets, not in local .env files.
# HATO_TMS_API_URL: Full URL of the deployed API (no trailing slash)
# HATO_TMS_API_TOKEN: API token from Settings → Regenerate Token in the Web UI
#                     (or via POST /api/v1/auth/token/regenerate)
# =============================================================
# HATO_TMS_API_URL=https://your-api.vercel.app
# HATO_TMS_API_TOKEN=
